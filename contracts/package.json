{
  "name": "somnia-reactive-orchestrator",
  "version": "1.0.0",
  "description": "Somnia Reactive Orchestrator - On-chain automation engine powered by Somnia Native Reactivity",
  "scripts": {
    "compile": "hardhat compile",
